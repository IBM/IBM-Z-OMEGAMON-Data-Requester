{
  "name": "public-common",
  "description": "",
  "scripts": {
    "verify": "pnpm prettier && pnpm lint && pnpm typecheck && pnpm test:ci",
    "test": "jest --watch --onlyChanged",
    "test:silent": "jest --watch --onlyChanged --silent",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --silent",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --check ./",
    "prettier:fix": "prettier --write ./",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "pnpm run lint --fix"
  },
  "author": "Rocket software",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "devDependencies": {
    "@swc/core": "catalog:",
    "@swc/helpers": "catalog:",
    "@swc/jest": "catalog:",
    "@types/glob": "catalog:",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "ts-node": "catalog:",
    "devtools-configs": "workspace:*"
  },
  "peerDependencies": {
    "rxjs": "catalog:"
  },
  "resolutions": {
    "rxjs": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<4": "^3.1.3",
      "picomatch@<3": "^2.3.2"
    }
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "pnpm@10.32.1"
}
