{
  "name": "public-ui",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite build --watch",
    "verifyAndBuild": "pnpm prettier && pnpm lint && pnpm typecheck && pnpm build",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "prettier": "prettier --check ./",
    "prettier:fix": "prettier --write ./",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "pnpm run lint --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest --watch --onlyChanged",
    "test:silent": "jest --watch --onlyChanged --silent",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --silent"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10"
  },
  "devDependencies": {
    "@carbon/icons-react": "catalog:",
    "@carbon/react": "catalog:",
    "@carbon/styles": "catalog:",
    "@carbon/themes": "catalog:",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@swc/jest": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/jest": "catalog:",
    "@types/lodash": "^4.17.24",
    "@types/node": "catalog:",
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "@vitejs/plugin-react-swc": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-storybook": "^10.4.0",
    "glob": "catalog:",
    "globals": "catalog:",
    "jest": "catalog:",
    "lodash": "^4.18.1",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "storybook": "^10.4.0",
    "tailwindcss": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-svgr": "catalog:",
    "devtools-configs": "workspace:*"
  },
  "//*peerDependencies": [
    "in devDependencies react18 to ensure compatibility with grafana-plugin",
    "in peerDependencies react18or19 to use React from consuming app (admin-app / grafana-plugin)"
  ],
  "peerDependencies": {
    "public-common": "workspace:*",
    "react": "catalog:react18or19",
    "react-dom": "catalog:react18or19"
  },
  "files": [
    "./dist"
  ],
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.0",
      "minimatch@<4": "^3.1.3",
      "picomatch@<3": "^2.3.2"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
